\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Attention-gate weights over Stage-2 v4.3 training. The GNN branch converges to weight $\approx 0.72$ from $\approx $ epoch 25, the reverse of the CNN-dominant pattern seen in v4 binary (Section~\ref {ssec:hybrid}) and in v4.1 baseline (Figure~\ref {fig:v4_1_training} right). When the head distinguishes three mechanistically distinct top-level classes, global $k$-mer composition becomes the more informative branch (cf.~Section~\ref {ssec:hybrid_disc}).}}{20}{figure.caption.25}\protected@file@percent }
\newlabel{fig:gate_weights}{{7}{20}{Attention-gate weights over Stage-2 v4.3 training. The GNN branch converges to weight $\approx 0.72$ from $\approx $ epoch 25, the reverse of the CNN-dominant pattern seen in v4 binary (Section~\ref {ssec:hybrid}) and in v4.1 baseline (Figure~\ref {fig:v4_1_training} right). When the head distinguishes three mechanistically distinct top-level classes, global $k$-mer composition becomes the more informative branch (cf.~Section~\ref {ssec:hybrid_disc})}{figure.caption.25}{}}
