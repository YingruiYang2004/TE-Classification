\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces v4.3 classification performance on held-out curated libraries from the mini benchmark. ``Matched sequences'' denotes the evaluable subset after class filtering and label mapping to the model vocabulary.}}{19}{table.3}\protected@file@percent }
\newlabel{tab:mini_benchmark}{{3}{19}{v4.3 classification performance on held-out curated libraries from the mini benchmark. ``Matched sequences'' denotes the evaluable subset after class filtering and label mapping to the model vocabulary}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Transfer learning performance on three held-out species. Left: per-class macro F1 (DNA / LTR / LINE) broken down by species. Right: overall class accuracy, class macro F1, superfamily accuracy, and superfamily macro F1 per species. Platypus achieves the highest class-level F1, while Zebra finch shows substantial degradation driven by LTR element misclassification.}}{19}{figure.9}\protected@file@percent }
\newlabel{fig:transfer_class_accuracy}{{9}{19}{Transfer learning performance on three held-out species. Left: per-class macro F1 (DNA / LTR / LINE) broken down by species. Right: overall class accuracy, class macro F1, superfamily accuracy, and superfamily macro F1 per species. Platypus achieves the highest class-level F1, while Zebra finch shows substantial degradation driven by LTR element misclassification}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Per-superfamily F1 heatmap across the three held-out species. Each cell shows the binary F1 for one superfamily in one species; grey indicates the superfamily is absent from that library. Superfamilies with broad amniote representation (DNA/hAT, LINE/CR1) generalise well, while avian-specific or rare LTR superfamilies score near zero, revealing the lineage-specific nature of TE sequence features.}}{20}{figure.10}\protected@file@percent }
\newlabel{fig:transfer_sf_heatmap}{{10}{20}{Per-superfamily F1 heatmap across the three held-out species. Each cell shows the binary F1 for one superfamily in one species; grey indicates the superfamily is absent from that library. Superfamilies with broad amniote representation (DNA/hAT, LINE/CR1) generalise well, while avian-specific or rare LTR superfamilies score near zero, revealing the lineage-specific nature of TE sequence features}{figure.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.7}Unsupervised Clustering of TE Sequences}{20}{subsection.2.7}\protected@file@percent }
\newlabel{ssec:clustering}{{2.7}{20}{Unsupervised Clustering of TE Sequences}{subsection.2.7}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.7.1}Contrastive Learning Framework}{20}{subsubsection.2.7.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Error analysis for the top-12 most misclassified superfamilies per held-out species. Red bars show the SF-level error rate (fraction of true-label sequences that are misassigned at superfamily level); orange bars show the class-level error rate. For Zebra finch, the near-coincidence of SF and class error rates for LTR families confirms that top-level class discrimination fails, not only fine-grained resolution.}}{21}{figure.11}\protected@file@percent }
\newlabel{fig:transfer_error_analysis}{{11}{21}{Error analysis for the top-12 most misclassified superfamilies per held-out species. Red bars show the SF-level error rate (fraction of true-label sequences that are misassigned at superfamily level); orange bars show the class-level error rate. For Zebra finch, the near-coincidence of SF and class error rates for LTR families confirms that top-level class discrimination fails, not only fine-grained resolution}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Row-normalised class-level confusion matrices for v4.3 applied to the three held-out species. Cell values show the fraction of true-class sequences assigned to each predicted class, with raw counts in parentheses. Zebra finch (left) shows the most severe off-diagonal mass for LTR elements, while Platypus (centre) and Alligator (right) exhibit cleaner diagonal structure, consistent with their higher overall transfer accuracy.}}{21}{figure.12}\protected@file@percent }
\newlabel{fig:transfer_confusion}{{12}{21}{Row-normalised class-level confusion matrices for v4.3 applied to the three held-out species. Cell values show the fraction of true-class sequences assigned to each predicted class, with raw counts in parentheses. Zebra finch (left) shows the most severe off-diagonal mass for LTR elements, while Platypus (centre) and Alligator (right) exhibit cleaner diagonal structure, consistent with their higher overall transfer accuracy}{figure.12}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.7.2}Embedding Space Geometry}{21}{subsubsection.2.7.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.7.3}Hierarchical Clustering and Subclusters}{22}{subsubsection.2.7.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Training history for supervised contrastive learning (SupCon) model with canvas-perturbed sequence pairs (temperature $\tau = 0.07$). Loss convergence after $\sim $15 epochs with minimal overfitting indicates robust self-supervised feature learning. The unsupervised model (trained only on perturbed pairs, no labels) recovered 83\% of supervised clustering separation (2.31$\times $ vs. 2.78$\times $), demonstrating that sequence composition alone encodes substantial class structure.}}{22}{figure.13}\protected@file@percent }
\newlabel{fig:contrastive_training}{{13}{22}{Training history for supervised contrastive learning (SupCon) model with canvas-perturbed sequence pairs (temperature $\tau = 0.07$). Loss convergence after $\sim $15 epochs with minimal overfitting indicates robust self-supervised feature learning. The unsupervised model (trained only on perturbed pairs, no labels) recovered 83\% of supervised clustering separation (2.31$\times $ vs. 2.78$\times $), demonstrating that sequence composition alone encodes substantial class structure}{figure.13}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.7.4}UMAP Visualization and Interpretability}{22}{subsubsection.2.7.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces UMAP projection of contrastive learning embeddings (SupCon-trained on canvas-perturbed pairs, 50 epochs). Despite training without class labels, the model recovers clear class-level separation (DNA/LTR/LINE), with partial superfamily ordering. Comparison with supervised embeddings (Figure~\ref {fig:superfamily_umap}) reveals that self-supervised learning captures comparable within-class structure, validating the utility of unsupervised TE clustering for downstream applications.}}{23}{figure.14}\protected@file@percent }
\newlabel{fig:contrastive_umap}{{14}{23}{UMAP projection of contrastive learning embeddings (SupCon-trained on canvas-perturbed pairs, 50 epochs). Despite training without class labels, the model recovers clear class-level separation (DNA/LTR/LINE), with partial superfamily ordering. Comparison with supervised embeddings (Figure~\ref {fig:superfamily_umap}) reveals that self-supervised learning captures comparable within-class structure, validating the utility of unsupervised TE clustering for downstream applications}{figure.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces UMAP projection of learned embeddings colored by TE superfamily. Clear separation of top-level classes (DNA, LTR, LINE) reflects robust high-level discrimination. Within-class structure shows superfamily-dependent ordering (e.g., DNA/hAT and DNA/TcMar-Tc1 occupy distinct peripheral regions), with some scatter suggesting continuous feature variation or annotation ambiguity within superfamilies.}}{24}{figure.15}\protected@file@percent }
\newlabel{fig:superfamily_umap}{{15}{24}{UMAP projection of learned embeddings colored by TE superfamily. Clear separation of top-level classes (DNA, LTR, LINE) reflects robust high-level discrimination. Within-class structure shows superfamily-dependent ordering (e.g., DNA/hAT and DNA/TcMar-Tc1 occupy distinct peripheral regions), with some scatter suggesting continuous feature variation or annotation ambiguity within superfamilies}{figure.15}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {2.7.5}Novel Substructure Discovery}{24}{subsubsection.2.7.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces UMAP projection with hierarchical Ward clustering results overlaid, showing detected subclusters within each top-level class. Silhouette coefficients (0.31 top-level, 0.18 subclusters) indicate moderate cluster separation. The 24 DNA subclusters reveal partial correspondence to known superfamilies, with ~5 subclusters mapping cleanly to individual families and remainder representing admixed or novel groups.}}{25}{figure.16}\protected@file@percent }
\newlabel{fig:clustering_umap}{{16}{25}{UMAP projection with hierarchical Ward clustering results overlaid, showing detected subclusters within each top-level class. Silhouette coefficients (0.31 top-level, 0.18 subclusters) indicate moderate cluster separation. The 24 DNA subclusters reveal partial correspondence to known superfamilies, with ~5 subclusters mapping cleanly to individual families and remainder representing admixed or novel groups}{figure.16}{}}
