\newlabel{fig:v4_3_confusion}{{6}{20}{Confusion matrices for v4.3 on the species-disjoint Pantera test set: three-class (left) and the ten most abundant superfamilies (right). Top-level separation is near-perfect; superfamily confusions concentrate within-class}{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Attention-gate weights over v4.3 training. The GNN branch converges to weight $\approx 0.72$ from $\approx $ epoch 25, the reverse of the CNN-dominant pattern seen in v4 binary (Section~\ref {ssec:hybrid}) and in v4.1 baseline (Figure~\ref {fig:v4_1_training} right). When the head distinguishes three mechanistically distinct top-level classes, global $k$-mer composition becomes the more informative branch (cf.~Section~\ref {ssec:hybrid_disc}).}}{20}{figure.caption.25}\protected@file@percent }
\newlabel{fig:gate_weights}{{7}{20}{Attention-gate weights over v4.3 training. The GNN branch converges to weight $\approx 0.72$ from $\approx $ epoch 25, the reverse of the CNN-dominant pattern seen in v4 binary (Section~\ref {ssec:hybrid}) and in v4.1 baseline (Figure~\ref {fig:v4_1_training} right). When the head distinguishes three mechanistically distinct top-level classes, global $k$-mer composition becomes the more informative branch (cf.~Section~\ref {ssec:hybrid_disc})}{figure.caption.25}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.2}K-mer features dominate the three-class head}{20}{subsubsection.3.3.2}\protected@file@percent }
\citation{wells2020field}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Standalone $k$-mer baseline for top-level three-class classification (DNA/LTR/LINE). Left: PCA (unsupervised) on canonical 7-mer hashed window features only weakly separates the three classes. Middle: supervised LDA on the same features cleanly separates them (LD1+LD2 capture 100\% of between-class variance by construction); 5-fold CV macro $F_1 = 0.890 \pm 0.009$, against $0.853$ for logistic regression and $0.849$ for random forest. Right: t-SNE leaves the classes substantially intermixed. The supervised projection (and the LR/RF/LDA scores) confirms that 7-mer composition carries strong class-level information, justifying the GNN branch of the hybrid architecture, while the unsupervised projections show this signal is not aligned with the dominant axes of variance.}}{21}{figure.caption.26}\protected@file@percent }
\newlabel{fig:kmer_separation}{{8}{21}{Standalone $k$-mer baseline for top-level three-class classification (DNA/LTR/LINE). Left: PCA (unsupervised) on canonical 7-mer hashed window features only weakly separates the three classes. Middle: supervised LDA on the same features cleanly separates them (LD1+LD2 capture 100\% of between-class variance by construction); 5-fold CV macro $F_1 = 0.890 \pm 0.009$, against $0.853$ for logistic regression and $0.849$ for random forest. Right: t-SNE leaves the classes substantially intermixed. The supervised projection (and the LR/RF/LDA scores) confirms that 7-mer composition carries strong class-level information, justifying the GNN branch of the hybrid architecture, while the unsupervised projections show this signal is not aligned with the dominant axes of variance}{figure.caption.26}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Within-class superfamily discrimination using canonical $k$-mer frequencies ($k$=5, 5-fold CV, 2000-per-class cap). Near-chance performance confirms that fine-grained classification is driven by the CNN branch, not by $k$-mer composition.}}{21}{table.caption.27}\protected@file@percent }
\newlabel{tab:kmer_within_class}{{6}{21}{Within-class superfamily discrimination using canonical $k$-mer frequencies ($k$=5, 5-fold CV, 2000-per-class cap). Near-chance performance confirms that fine-grained classification is driven by the CNN branch, not by $k$-mer composition}{table.caption.27}{}}
