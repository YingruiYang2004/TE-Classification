\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Per-class macro F1 for the v4.3 model on held-out benchmark species, obtained from \texttt  {transfer\_class\_accuracy.png}. Values are approximate visual reads from the left-panel bar chart; see Figure~\ref {fig:transfer_class_accuracy} for the source.}}{22}{table.caption.19}\protected@file@percent }
\newlabel{tab:mini_benchmark_perclass}{{9}{22}{Per-class macro F1 for the v4.3 model on held-out benchmark species, obtained from \texttt {transfer\_class\_accuracy.png}. Values are approximate visual reads from the left-panel bar chart; see Figure~\ref {fig:transfer_class_accuracy} for the source}{table.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Transfer learning performance on three held-out species. Left: per-class macro F1 (DNA / LTR / LINE) broken down by species. Right: overall class accuracy, class macro F1, superfamily accuracy, and superfamily macro F1 per species. Platypus achieves the highest class-level F1, while Zebra finch shows substantial degradation driven by LTR element misclassification.}}{23}{figure.caption.20}\protected@file@percent }
\newlabel{fig:transfer_class_accuracy}{{9}{23}{Transfer learning performance on three held-out species. Left: per-class macro F1 (DNA / LTR / LINE) broken down by species. Right: overall class accuracy, class macro F1, superfamily accuracy, and superfamily macro F1 per species. Platypus achieves the highest class-level F1, while Zebra finch shows substantial degradation driven by LTR element misclassification}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Per-superfamily F1 heatmap across the three held-out species. Each cell shows the binary F1 for one superfamily in one species; grey indicates the superfamily is absent from that library. Superfamilies with broad amniote representation (DNA/hAT, LINE/CR1) generalise well, while avian-specific or rare LTR superfamilies score near zero, revealing the lineage-specific nature of TE sequence features.}}{24}{figure.caption.21}\protected@file@percent }
\newlabel{fig:transfer_sf_heatmap}{{10}{24}{Per-superfamily F1 heatmap across the three held-out species. Each cell shows the binary F1 for one superfamily in one species; grey indicates the superfamily is absent from that library. Superfamilies with broad amniote representation (DNA/hAT, LINE/CR1) generalise well, while avian-specific or rare LTR superfamilies score near zero, revealing the lineage-specific nature of TE sequence features}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Error analysis for the top-12 most misclassified superfamilies per held-out species. Red bars show the SF-level error rate (fraction of true-label sequences that are misassigned at superfamily level); orange bars show the class-level error rate. For Zebra finch, the near-coincidence of SF and class error rates for LTR families confirms that top-level class discrimination fails, not only fine-grained resolution.}}{24}{figure.caption.22}\protected@file@percent }
\newlabel{fig:transfer_error_analysis}{{11}{24}{Error analysis for the top-12 most misclassified superfamilies per held-out species. Red bars show the SF-level error rate (fraction of true-label sequences that are misassigned at superfamily level); orange bars show the class-level error rate. For Zebra finch, the near-coincidence of SF and class error rates for LTR families confirms that top-level class discrimination fails, not only fine-grained resolution}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Row-normalised class-level confusion matrices for v4.3 applied to the three held-out species. Cell values show the fraction of true-class sequences assigned to each predicted class, with raw counts in parentheses. Zebra finch (left) shows the most severe off-diagonal mass for LTR elements, while Platypus (centre) and Alligator (right) exhibit cleaner diagonal structure, consistent with their higher overall transfer accuracy.}}{25}{figure.caption.23}\protected@file@percent }
\newlabel{fig:transfer_confusion}{{12}{25}{Row-normalised class-level confusion matrices for v4.3 applied to the three held-out species. Cell values show the fraction of true-class sequences assigned to each predicted class, with raw counts in parentheses. Zebra finch (left) shows the most severe off-diagonal mass for LTR elements, while Platypus (centre) and Alligator (right) exhibit cleaner diagonal structure, consistent with their higher overall transfer accuracy}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces In-distribution test-set confusion structure for v4.3. (A) Row-normalised class-level confusion matrix on the held-out test split. (B) Top-20 superfamily confusion pairs ranked by misclassification count, illustrating that the dominant errors are within-class superfamily confusions. (C) Top-15 superfamily recall heatmap (rows: true superfamily; columns: predicted), highlighting the within-class clustering of errors among closely related superfamilies.}}{25}{figure.caption.24}\protected@file@percent }
\newlabel{fig:test_confusion_structure}{{13}{25}{In-distribution test-set confusion structure for v4.3. (A) Row-normalised class-level confusion matrix on the held-out test split. (B) Top-20 superfamily confusion pairs ranked by misclassification count, illustrating that the dominant errors are within-class superfamily confusions. (C) Top-15 superfamily recall heatmap (rows: true superfamily; columns: predicted), highlighting the within-class clustering of errors among closely related superfamilies}{figure.caption.24}{}}
\citation{simonyan2014deep}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Saliency as a Sanity Check}{26}{subsection.3.6}\protected@file@percent }
\newlabel{ssec:saliency}{{3.6}{26}{Saliency as a Sanity Check}{subsection.3.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Occlusion-based saliency for four representative misclassified test sequences chosen from the dominant superfamily confusion pairs identified in Figure~\ref {fig:test_confusion_structure} (DNA/hAT$\rightarrow $DNA, LTR/Gypsy$\rightarrow $LTR/Pao, DNA$\rightarrow $DNA/hAT, LINE/L1$\rightarrow $LINE/L1-Tx1). For each example, two curves show the per-position drop in the true-class logit (blue) and in the predicted-class logit (orange) when a sliding window is masked, so positive values mark regions important for the corresponding class. The panels reveals that a confident error like LINE/L1$\rightarrow $LINE/L1-Tx1 typically shows broadly negative true-class saliency across the body, while ambiguous within-class errors (LTR/Gypsy$\leftrightarrow $LTR/Pao) show overlapping true- and predicted-class envelopes consistent with shared internal motifs.}}{26}{figure.caption.25}\protected@file@percent }
\newlabel{fig:saliency_analysis}{{14}{26}{Occlusion-based saliency for four representative misclassified test sequences chosen from the dominant superfamily confusion pairs identified in Figure~\ref {fig:test_confusion_structure} (DNA/hAT$\rightarrow $DNA, LTR/Gypsy$\rightarrow $LTR/Pao, DNA$\rightarrow $DNA/hAT, LINE/L1$\rightarrow $LINE/L1-Tx1). For each example, two curves show the per-position drop in the true-class logit (blue) and in the predicted-class logit (orange) when a sliding window is masked, so positive values mark regions important for the corresponding class. The panels reveals that a confident error like LINE/L1$\rightarrow $LINE/L1-Tx1 typically shows broadly negative true-class saliency across the body, while ambiguous within-class errors (LTR/Gypsy$\leftrightarrow $LTR/Pao) show overlapping true- and predicted-class envelopes consistent with shared internal motifs}{figure.caption.25}{}}
