\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Training history for the v5 contrastive model (combined SupCon + cross-entropy + center loss). The combined objective stabilises the embedding geometry compared to pure SupCon, preventing arbitrary inter-superfamily separation while maintaining cluster compactness.}}{28}{figure.caption.27}\protected@file@percent }
\newlabel{fig:contrastive_training}{{15}{28}{Training history for the v5 contrastive model (combined SupCon + cross-entropy + center loss). The combined objective stabilises the embedding geometry compared to pure SupCon, preventing arbitrary inter-superfamily separation while maintaining cluster compactness}{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.7.4}Novel Substructure Discovery}{28}{subsubsection.3.7.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Ten largest mixed HDBSCAN clusters in the DNA transposon embedding space (dominant superfamily $<$ 80\% of members, sorted by size). Cluster IDs are HDBSCAN labels; the prefix indicates the nearest annotated superfamily branch. ``Unknown'' denotes sequences not assigned to a named superfamily in the Pantera annotations.}}{28}{table.caption.31}\protected@file@percent }
\newlabel{tab:novel_subclusters}{{11}{28}{Ten largest mixed HDBSCAN clusters in the DNA transposon embedding space (dominant superfamily $<$ 80\% of members, sorted by size). Cluster IDs are HDBSCAN labels; the prefix indicates the nearest annotated superfamily branch. ``Unknown'' denotes sequences not assigned to a named superfamily in the Pantera annotations}{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces UMAP projection of contrastive learning embeddings (v5 combined-loss model). The model recovers class-level structure (DNA/LTR/LINE), with partial superfamily ordering visible within each cluster. Note that UMAP axes have no direct biological interpretation; the 2D layout preserves local neighbourhood structure in the high-dimensional embedding space.}}{29}{figure.caption.28}\protected@file@percent }
\newlabel{fig:contrastive_umap}{{16}{29}{UMAP projection of contrastive learning embeddings (v5 combined-loss model). The model recovers class-level structure (DNA/LTR/LINE), with partial superfamily ordering visible within each cluster. Note that UMAP axes have no direct biological interpretation; the 2D layout preserves local neighbourhood structure in the high-dimensional embedding space}{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces UMAP projection of V4 hybrid model embeddings coloured by top-level TE class. DNA transposons (blue), LTR/retrotransposons (pink), LINE/SINE elements (green), and unannotated sequences (grey) form broadly separated regions, demonstrating that the supervised embedding space captures coarse TE class structure. Overlapping regions reflect sequences near class boundaries or with ambiguous annotations. UMAP axes have no direct biological interpretation; the 2D layout preserves local neighbourhood structure in the high-dimensional embedding space.}}{30}{figure.caption.29}\protected@file@percent }
\newlabel{fig:superfamily_umap}{{17}{30}{UMAP projection of V4 hybrid model embeddings coloured by top-level TE class. DNA transposons (blue), LTR/retrotransposons (pink), LINE/SINE elements (green), and unannotated sequences (grey) form broadly separated regions, demonstrating that the supervised embedding space captures coarse TE class structure. Overlapping regions reflect sequences near class boundaries or with ambiguous annotations. UMAP axes have no direct biological interpretation; the 2D layout preserves local neighbourhood structure in the high-dimensional embedding space}{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces UMAP projection of DNA transposon embeddings coloured by HDBSCAN cluster identity. The top 20 largest clusters are shown in distinct colours; remaining points are shown in light grey. A total of 72 clusters were discovered, revealing substantial substructure within the DNA transposon class beyond the seven annotated superfamilies. Spatially isolated clusters suggest the model has learned sequence groupings that may correspond to novel biological subfamilies or convergently-evolved sequence variants. UMAP axes have no direct biological interpretation.}}{31}{figure.caption.30}\protected@file@percent }
\newlabel{fig:clustering_umap}{{18}{31}{UMAP projection of DNA transposon embeddings coloured by HDBSCAN cluster identity. The top 20 largest clusters are shown in distinct colours; remaining points are shown in light grey. A total of 72 clusters were discovered, revealing substantial substructure within the DNA transposon class beyond the seven annotated superfamilies. Spatially isolated clusters suggest the model has learned sequence groupings that may correspond to novel biological subfamilies or convergently-evolved sequence variants. UMAP axes have no direct biological interpretation}{figure.caption.30}{}}
