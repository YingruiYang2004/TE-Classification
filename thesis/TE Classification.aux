\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Confusion matrices for v4.3 final hybrid model showing three-class (DNA/LTR/LINE, left) and 23-superfamily (right) classification performance on held-out VGP test set. Strong separation of top-level classes (off-diagonal elements in left matrix are minimal) contrasts with moderate superfamily confusions, reflecting the biological hierarchy of TE classification.}}{15}{figure.4}\protected@file@percent }
\newlabel{fig:v4_3_confusion}{{4}{15}{Confusion matrices for v4.3 final hybrid model showing three-class (DNA/LTR/LINE, left) and 23-superfamily (right) classification performance on held-out VGP test set. Strong separation of top-level classes (off-diagonal elements in left matrix are minimal) contrasts with moderate superfamily confusions, reflecting the biological hierarchy of TE classification}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Learned attention gate weights evolution during v4.3 training, showing CNN vs. GNN contribution weights over 40 training epochs. Weights stabilize by epoch 5 at approximately 66\% CNN / 34\% GNN for three-class task, indicating that local sequence motifs (CNN) provide more diagnostic signal than global compositional patterns (GNN) for fine-grained superfamily discrimination.}}{15}{figure.5}\protected@file@percent }
\newlabel{fig:gate_weights}{{5}{15}{Learned attention gate weights evolution during v4.3 training, showing CNN vs. GNN contribution weights over 40 training epochs. Weights stabilize by epoch 5 at approximately 66\% CNN / 34\% GNN for three-class task, indicating that local sequence motifs (CNN) provide more diagnostic signal than global compositional patterns (GNN) for fine-grained superfamily discrimination}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces K-mer feature separability for top-level classes, showing that 7-mer frequency composition alone achieves ~85\% macro F1 on class discrimination (DNA/LTR/LINE). This analysis justifies the GNN component of the hybrid architecture: compositional signals provide strong priors for class identity, reducing the hypothesis space for CNN-driven fine-grained superfamily classification.}}{16}{figure.6}\protected@file@percent }
\newlabel{fig:kmer_separation}{{6}{16}{K-mer feature separability for top-level classes, showing that 7-mer frequency composition alone achieves ~85\% macro F1 on class discrimination (DNA/LTR/LINE). This analysis justifies the GNN component of the hybrid architecture: compositional signals provide strong priors for class identity, reducing the hypothesis space for CNN-driven fine-grained superfamily classification}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Progression of TE classification models across versions (v3→v4→v4.3). Metrics shown are test-set results except where noted. Binary task = DNA vs. non-DNA; Superfamily task = assignment to individual families (7 in DNA-only, 23 across three classes). Key improvement from v4.2 to v4.3: reduced overfitting via early stopping and species withholding.}}{16}{table.1}\protected@file@percent }
\newlabel{tab:model\_progression}{{1}{16}{Progression of TE classification models across versions (v3→v4→v4.3). Metrics shown are test-set results except where noted. Binary task = DNA vs. non-DNA; Superfamily task = assignment to individual families (7 in DNA-only, 23 across three classes). Key improvement from v4.2 to v4.3: reduced overfitting via early stopping and species withholding}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Saliency maps (input-level gradients) for v4.3 model, aggregated by superfamily. Per-position attribution scores reveal stereotyped patterns: DNA transposons show sharp peaks at sequence boundaries (TIR regions), LTR elements show symmetric internal patterns characteristic of retroviral structure, and LINEs concentrate saliency near poly(A) motifs. This biologically interpretable attribution validates that convolutional layers learn to detect canonical TE-specific features.}}{17}{figure.7}\protected@file@percent }
\newlabel{fig:saliency_analysis}{{7}{17}{Saliency maps (input-level gradients) for v4.3 model, aggregated by superfamily. Per-position attribution scores reveal stereotyped patterns: DNA transposons show sharp peaks at sequence boundaries (TIR regions), LTR elements show symmetric internal patterns characteristic of retroviral structure, and LINEs concentrate saliency near poly(A) motifs. This biologically interpretable attribution validates that convolutional layers learn to detect canonical TE-specific features}{figure.7}{}}
