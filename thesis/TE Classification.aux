\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.7.1}Embedding Space Geometry}{27}{subsubsection.3.7.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Per-superfamily embedding compactness in the v5 contrastive model, measured as mean $L_2$ distance from each sequence to its superfamily centroid (subsampled to 200 per superfamily where $n > 200$). Lower values indicate more compact, stereotyped clusters. Since v5 was trained specifically on DNA transposons, only the six DNA superfamilies present in the embedding space are reported.}}{27}{table.caption.26}\protected@file@percent }
\newlabel{tab:l2_compactness}{{10}{27}{Per-superfamily embedding compactness in the v5 contrastive model, measured as mean $L_2$ distance from each sequence to its superfamily centroid (subsampled to 200 per superfamily where $n > 200$). Lower values indicate more compact, stereotyped clusters. Since v5 was trained specifically on DNA transposons, only the six DNA superfamilies present in the embedding space are reported}{table.caption.26}{}}
