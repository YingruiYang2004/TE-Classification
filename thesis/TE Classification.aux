\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Mini-benchmark performance for v4.3 and v4.3-singlefold on the three excised amniote genomes. Class metrics use all 1{,}654 DNA / LTR / LINE sequences; superfamily metrics restrict to the 897 entries whose superfamily tag is in the model's 23-SF vocabulary. The class-level advantage ($+0.156$) tracks the corresponding Pantera-test gap (Section~\ref {ssec:stage3}); at the superfamily level the gap reverses sign ($-0.019$ in v4.3's favour becomes $+0.019$ in v4.3-singlefold's favour).}}{23}{table.caption.30}\protected@file@percent }
\newlabel{tab:mini_benchmark}{{8}{23}{Mini-benchmark performance for v4.3 and v4.3-singlefold on the three excised amniote genomes. Class metrics use all 1{,}654 DNA / LTR / LINE sequences; superfamily metrics restrict to the 897 entries whose superfamily tag is in the model's 23-SF vocabulary. The class-level advantage ($+0.156$) tracks the corresponding Pantera-test gap (Section~\ref {ssec:stage3}); at the superfamily level the gap reverses sign ($-0.019$ in v4.3's favour becomes $+0.019$ in v4.3-singlefold's favour)}{table.caption.30}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Macro $F_1$ on the top-class level on the mini-benchmark for Stage-2 v4.3 (top three rows) and Stage-3 v4.3-singlefold (bottom three rows). v4.3 model is in general outperforming v4.3-singlefold at this level, but the gap is not consistent across species and classes. The largest residual error budget is in LTR classification, followed by DNA on zebra finch. }}{23}{table.caption.31}\protected@file@percent }
\newlabel{tab:mini_benchmark_perclass}{{9}{23}{Macro $F_1$ on the top-class level on the mini-benchmark for Stage-2 v4.3 (top three rows) and Stage-3 v4.3-singlefold (bottom three rows). v4.3 model is in general outperforming v4.3-singlefold at this level, but the gap is not consistent across species and classes. The largest residual error budget is in LTR classification, followed by DNA on zebra finch}{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Per-superfamily $F_1$ on the mini-benchmark (top 10 superfamilies by total support across the three species), comparing v4.3 (blue) and v4.3-singlefold (orange). The class-level advantage of v4.3 (Table~\ref {tab:mini_benchmark}) does not extend to the superfamily level: per-SF the two stages alternate which is higher and the gap is small in absolute terms.}}{23}{figure.caption.32}\protected@file@percent }
\newlabel{fig:mini_benchmark_perSF_bar}{{9}{23}{Per-superfamily $F_1$ on the mini-benchmark (top 10 superfamilies by total support across the three species), comparing v4.3 (blue) and v4.3-singlefold (orange). The class-level advantage of v4.3 (Table~\ref {tab:mini_benchmark}) does not extend to the superfamily level: per-SF the two stages alternate which is higher and the gap is small in absolute terms}{figure.caption.32}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Per-superfamily $F_1$ heatmap on the mini-benchmark, top 14 superfamilies by total support across the three excised amniote genomes; left: v4.3 (rotating-CV inner), right: v4.3-singlefold (disjoint inner val). Each cell prints both the $F_1$ score and the test-set support $n$ for that (species, superfamily) pair; empty cells indicate no entries in the species' test data for that superfamily within the model's 23-SF vocabulary. Remark that most low-$F_1$ cells coincide with very small support ($n \le 10$), where a single mis-prediction is enough to drive $F_1$ to $0$ (e.g.\ LTR/Gypsy on Platypus with $n=5$, LINE/L1 with $n=1$ across both birds and platypus, DNA/TcMar-Tc1 with $n=1$--$3$); on superfamilies with moderate-to-large support ($n \ge 25$) the model is generally competitive (LINE/CR1 $0.60$--$0.82$, LINE/L2 $0.62$--$0.88$, LTR/Gypsy on Alligator $n=260$ at $0.30$--$0.45$), the genuine residual error budget concentrating on DNA/PIF-Harbinger ($0.00$--$0.22$ at $n=103$ in Alligator) and DNA/hAT (Section~\ref {ssec:stage3}) rather than being spread across the table. The two stages agree closely cell-by-cell on most superfamilies, with the few large differences (LTR/DIRS, LTR catch-all) again sitting on small-support cells.}}{24}{figure.caption.33}\protected@file@percent }
\newlabel{fig:mini_benchmark_perSF_heatmap}{{10}{24}{Per-superfamily $F_1$ heatmap on the mini-benchmark, top 14 superfamilies by total support across the three excised amniote genomes; left: v4.3 (rotating-CV inner), right: v4.3-singlefold (disjoint inner val). Each cell prints both the $F_1$ score and the test-set support $n$ for that (species, superfamily) pair; empty cells indicate no entries in the species' test data for that superfamily within the model's 23-SF vocabulary. Remark that most low-$F_1$ cells coincide with very small support ($n \le 10$), where a single mis-prediction is enough to drive $F_1$ to $0$ (e.g.\ LTR/Gypsy on Platypus with $n=5$, LINE/L1 with $n=1$ across both birds and platypus, DNA/TcMar-Tc1 with $n=1$--$3$); on superfamilies with moderate-to-large support ($n \ge 25$) the model is generally competitive (LINE/CR1 $0.60$--$0.82$, LINE/L2 $0.62$--$0.88$, LTR/Gypsy on Alligator $n=260$ at $0.30$--$0.45$), the genuine residual error budget concentrating on DNA/PIF-Harbinger ($0.00$--$0.22$ at $n=103$ in Alligator) and DNA/hAT (Section~\ref {ssec:stage3}) rather than being spread across the table. The two stages agree closely cell-by-cell on most superfamilies, with the few large differences (LTR/DIRS, LTR catch-all) again sitting on small-support cells}{figure.caption.33}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Full-Corpus Inference and Out-of-Vocabulary Behaviour}{25}{subsection.3.6}\protected@file@percent }
\newlabel{ssec:full_corpus}{{3.6}{25}{Full-Corpus Inference and Out-of-Vocabulary Behaviour}{subsection.3.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Class- and superfamily-level predictions of the Stage-2 v4.3 hybrid on the full VGP corpus, broken down by RepeatModeler header class. The three major header classes $\{\text  {DNA},\text  {LTR},\text  {LINE}\}$ are within the training vocabulary; $\{\text  {SINE},\text  {RC},\text  {PLE}\}$ are out-of-vocabulary; ``Unknown'' covers sequences for which the upstream Pantera transposase scan returned no tag. For each group, the three rows show what fraction of that group is sent to each of the three trained classes, together with the mean class-head and mean SF-head softmax confidence on those predictions. Class-level confidence is essentially saturated everywhere ($\geq 0.99$) regardless of whether the true class is in vocabulary: the model assigns 98\,\% of SINEs to DNA at mean class confidence $0.999$, illustrating that high softmax probability does not imply correctness once inputs leave the in-vocabulary classes. Superfamily-level confidence is markedly lower and varies systematically with input type, suggesting the SF-head margin would be a more useful flag for ambiguous or out-of-distribution inputs than the class-head margin. The Stage-3 single-fold model agrees on the SINE\,$\rightarrow $\,DNA assignment for 551/566 sequences.}}{25}{table.caption.34}\protected@file@percent }
\newlabel{tab:full_corpus_ood}{{10}{25}{Class- and superfamily-level predictions of the Stage-2 v4.3 hybrid on the full VGP corpus, broken down by RepeatModeler header class. The three major header classes $\{\text {DNA},\text {LTR},\text {LINE}\}$ are within the training vocabulary; $\{\text {SINE},\text {RC},\text {PLE}\}$ are out-of-vocabulary; ``Unknown'' covers sequences for which the upstream Pantera transposase scan returned no tag. For each group, the three rows show what fraction of that group is sent to each of the three trained classes, together with the mean class-head and mean SF-head softmax confidence on those predictions. Class-level confidence is essentially saturated everywhere ($\geq 0.99$) regardless of whether the true class is in vocabulary: the model assigns 98\,\% of SINEs to DNA at mean class confidence $0.999$, illustrating that high softmax probability does not imply correctness once inputs leave the in-vocabulary classes. Superfamily-level confidence is markedly lower and varies systematically with input type, suggesting the SF-head margin would be a more useful flag for ambiguous or out-of-distribution inputs than the class-head margin. The Stage-3 single-fold model agrees on the SINE\,$\rightarrow $\,DNA assignment for 551/566 sequences}{table.caption.34}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.7}Saliency as a Sanity Check}{26}{subsection.3.7}\protected@file@percent }
\newlabel{ssec:saliency}{{3.7}{26}{Saliency as a Sanity Check}{subsection.3.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Occlusion saliency for four representative misclassified test sequences from the v4.3 hybrid model, drawn from the dominant superfamily confusion pairs. Blue: probe targeting the true superfamily; red: probe targeting the predicted superfamily. Curves show the per-base logit drop after masking, with positive values indicating the class is supported locally, alongside the integrated drop $\Sigma \!\downarrow $ as the sum of per-position drops and the decision margin $f_{\text  {pred}}(x){-}f_{\text  {true}}(x)$. The four panels span a spectrum of error modes. \emph  {LTR/Gypsy$\to $LTR/Pao}: both $\Sigma \!\downarrow $ strongly positive, with Pao larger, indicating the sequence carries motifs from both superfamilies (manually confirmed) and the model breaks a tie. \emph  {DNA/hAT$\leftrightarrow $DNA}: the labelled-true class has small or negative $\Sigma \!\downarrow $ while the predicted class has a positive one, consistent with either a label-granularity mismatch (parent class vs.\ specific superfamily) or pipeline mis-annotation. \emph  {LINE/L1$\to $LINE/L1-Tx1}: local evidence strongly supports the predicted class, yet $\Sigma \!\downarrow _{\text  {L1-Tx1}}$ is comparably large and \emph  {negative}, indicating that the prediction was determined by the long-range features. }}{26}{figure.caption.35}\protected@file@percent }
\newlabel{fig:saliency_analysis}{{11}{26}{Occlusion saliency for four representative misclassified test sequences from the v4.3 hybrid model, drawn from the dominant superfamily confusion pairs. Blue: probe targeting the true superfamily; red: probe targeting the predicted superfamily. Curves show the per-base logit drop after masking, with positive values indicating the class is supported locally, alongside the integrated drop $\Sigma \!\downarrow $ as the sum of per-position drops and the decision margin $f_{\text {pred}}(x){-}f_{\text {true}}(x)$. The four panels span a spectrum of error modes. \emph {LTR/Gypsy$\to $LTR/Pao}: both $\Sigma \!\downarrow $ strongly positive, with Pao larger, indicating the sequence carries motifs from both superfamilies (manually confirmed) and the model breaks a tie. \emph {DNA/hAT$\leftrightarrow $DNA}: the labelled-true class has small or negative $\Sigma \!\downarrow $ while the predicted class has a positive one, consistent with either a label-granularity mismatch (parent class vs.\ specific superfamily) or pipeline mis-annotation. \emph {LINE/L1$\to $LINE/L1-Tx1}: local evidence strongly supports the predicted class, yet $\Sigma \!\downarrow _{\text {L1-Tx1}}$ is comparably large and \emph {negative}, indicating that the prediction was determined by the long-range features}{figure.caption.35}{}}
