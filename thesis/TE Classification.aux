\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Per-superfamily $F_1$ for v3 (CNN-only) and v4 (hybrid CNN+GNN), on a common stratified 20\,\% holdout ($n = 2{,}051$). The DNA row covers sequences annotated only at class level. The largest gain is in DNA/CMC, where the GNN's $k$-mer signal resolves confusion with generic-DNA sequences.}}{17}{table.caption.8}\protected@file@percent }
\newlabel{tab:v3_v4_sf_f1}{{4}{17}{Per-superfamily $F_1$ for v3 (CNN-only) and v4 (hybrid CNN+GNN), on a common stratified 20\,\% holdout ($n = 2{,}051$). The DNA row covers sequences annotated only at class level. The largest gain is in DNA/CMC, where the GNN's $k$-mer signal resolves confusion with generic-DNA sequences}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Confusion matrices for the v4 hybrid CNN+GNN model: binary DNA vs non-DNA (left) and DNA-superfamily classification across seven families (right). Binary accuracy improves from 91.3\,\% to 93.1\,\%; superfamily macro $F_1$ rises from 0.91 to 0.96, driven mainly by a large gain in DNA/CMC (see Table~\ref {tab:v3_v4_sf_f1}).}}{17}{figure.caption.9}\protected@file@percent }
\newlabel{fig:v4_confusion}{{3}{17}{Confusion matrices for the v4 hybrid CNN+GNN model: binary DNA vs non-DNA (left) and DNA-superfamily classification across seven families (right). Binary accuracy improves from 91.3\,\% to 93.1\,\%; superfamily macro $F_1$ rises from 0.91 to 0.96, driven mainly by a large gain in DNA/CMC (see Table~\ref {tab:v3_v4_sf_f1})}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Training curves for the v4 hybrid model across 40 epochs. Binary classification metrics (upper centre) stabilise early ($\sim $5 epochs), while superfamily macro $F_1$ (upper right) continues to improve gradually until $\sim $epoch 25 before plateauing. The attention gate weights (lower left) remain volatile throughout with no dominant branch. The combined score (0.5$\cdot $binary + 0.5$\cdot $SF macro $F_1$; lower right) peaks at epoch 39, which is the selected checkpoint.}}{18}{figure.caption.10}\protected@file@percent }
\newlabel{fig:v4_training}{{4}{18}{Training curves for the v4 hybrid model across 40 epochs. Binary classification metrics (upper centre) stabilise early ($\sim $5 epochs), while superfamily macro $F_1$ (upper right) continues to improve gradually until $\sim $epoch 25 before plateauing. The attention gate weights (lower left) remain volatile throughout with no dominant branch. The combined score (0.5$\cdot $binary + 0.5$\cdot $SF macro $F_1$; lower right) peaks at epoch 39, which is the selected checkpoint}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Multi-Class Extension: Three-Class Classification (v4.2 and v4.3)}{18}{subsection.3.4}\protected@file@percent }
\newlabel{ssec:fullset}{{3.4}{18}{Multi-Class Extension: Three-Class Classification (v4.2 and v4.3)}{subsection.3.4}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.1}Three-Class Reformulation}{18}{subsubsection.3.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.2}Overfitting Analysis in v4.2}{18}{subsubsection.3.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Training trajectory for v4.2 over 65 epochs. Left: training loss decreases to a plateau at $\approx $0.44. Centre: validation class macro F1 (teal) and superfamily macro F1 (orange) both climb monotonically to near-perfect values, which is a clear signature of overfitting. The dashed red line marks epoch 40, which was adopted as the training cutoff for v4.3. Right: attention gate weights over training; the CNN branch dominates at $\approx $0.88 while the GNN branch is suppressed ($\approx $0.12) throughout, the reverse of the GNN-dominant pattern observed in v4.3.}}{19}{figure.caption.11}\protected@file@percent }
\newlabel{fig:v4_2_training}{{5}{19}{Training trajectory for v4.2 over 65 epochs. Left: training loss decreases to a plateau at $\approx $0.44. Centre: validation class macro F1 (teal) and superfamily macro F1 (orange) both climb monotonically to near-perfect values, which is a clear signature of overfitting. The dashed red line marks epoch 40, which was adopted as the training cutoff for v4.3. Right: attention gate weights over training; the CNN branch dominates at $\approx $0.88 while the GNN branch is suppressed ($\approx $0.12) throughout, the reverse of the GNN-dominant pattern observed in v4.3}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Split-level performance for v4.2 at epoch 65 (best checkpoint). Near-perfect train and validation scores contrast with the test superfamily macro $F_1$ of 0.872, quantifying the overfitting gap of 0.127 at the superfamily level. The top-level class macro $F_1$ generalises considerably better (gap 0.016), confirming that three-class discrimination is inherently more robust than fine-grained superfamily assignment.}}{19}{table.caption.12}\protected@file@percent }
\newlabel{tab:v4_2_splits}{{5}{19}{Split-level performance for v4.2 at epoch 65 (best checkpoint). Near-perfect train and validation scores contrast with the test superfamily macro $F_1$ of 0.872, quantifying the overfitting gap of 0.127 at the superfamily level. The top-level class macro $F_1$ generalises considerably better (gap 0.016), confirming that three-class discrimination is inherently more robust than fine-grained superfamily assignment}{table.caption.12}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.3}Final Model (v4.3)}{19}{subsubsection.3.4.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.4}Performance (v4.3)}{19}{subsubsection.3.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Confusion matrices for v4.3 final hybrid model showing three-class (DNA/LTR/LINE, left) and superfamily (only with the top-10 most abundent superfamilies, right) classification performance on the testing set. Strong separation of top-level classes (off-diagonal elements in left matrix are minimal) contrasts with moderate superfamily confusions, reflecting the biological hierarchy of TE classification. But remark that the DNA superfamily classification results are not directly comparable to the previous binary models (v3/v4) because of the different training set (three species excluded) and the more challenging three-class setting.}}{20}{figure.caption.13}\protected@file@percent }
\newlabel{fig:v4_3_confusion}{{6}{20}{Confusion matrices for v4.3 final hybrid model showing three-class (DNA/LTR/LINE, left) and superfamily (only with the top-10 most abundent superfamilies, right) classification performance on the testing set. Strong separation of top-level classes (off-diagonal elements in left matrix are minimal) contrasts with moderate superfamily confusions, reflecting the biological hierarchy of TE classification. But remark that the DNA superfamily classification results are not directly comparable to the previous binary models (v3/v4) because of the different training set (three species excluded) and the more challenging three-class setting}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Learned attention gate weights evolution during v4.3 training, showing CNN vs.\ GNN contribution weights over 40 training epochs. Gate weights are variable across training folds and epochs with no clear stabilisation to a fixed ratio. GNN weighting generally dominates, indicating that global compositional patterns remain important even in the three-class setting.}}{20}{figure.caption.14}\protected@file@percent }
\newlabel{fig:gate_weights}{{7}{20}{Learned attention gate weights evolution during v4.3 training, showing CNN vs.\ GNN contribution weights over 40 training epochs. Gate weights are variable across training folds and epochs with no clear stabilisation to a fixed ratio. GNN weighting generally dominates, indicating that global compositional patterns remain important even in the three-class setting}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.5}K-mer Features Separate Top-Level Classes}{20}{subsubsection.3.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces K-mer feature separability for top-level classes, showing that 7-mer frequency composition alone achieves ~85\% macro F1 on class discrimination (DNA/LTR/LINE). This analysis justifies the GNN component of the hybrid architecture: compositional signals provide strong priors for class identity, reducing the hypothesis space for CNN-driven fine-grained superfamily classification.}}{21}{figure.caption.15}\protected@file@percent }
\newlabel{fig:kmer_separation}{{8}{21}{K-mer feature separability for top-level classes, showing that 7-mer frequency composition alone achieves ~85\% macro F1 on class discrimination (DNA/LTR/LINE). This analysis justifies the GNN component of the hybrid architecture: compositional signals provide strong priors for class identity, reducing the hypothesis space for CNN-driven fine-grained superfamily classification}{figure.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Within-class superfamily discrimination using canonical $k$-mer frequency features ($k$=5, logistic regression, 5-fold CV; sequences capped at 2000 per class). Near-chance performance ($\leq $0.10) confirms that $k$-mer composition alone cannot resolve superfamilies within a top-level class, motivating the hybrid CNN+GNN architecture.}}{21}{table.caption.16}\protected@file@percent }
\newlabel{tab:kmer_within_class}{{6}{21}{Within-class superfamily discrimination using canonical $k$-mer frequency features ($k$=5, logistic regression, 5-fold CV; sequences capped at 2000 per class). Near-chance performance ($\leq $0.10) confirms that $k$-mer composition alone cannot resolve superfamilies within a top-level class, motivating the hybrid CNN+GNN architecture}{table.caption.16}{}}
