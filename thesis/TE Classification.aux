\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Saliency as a Sanity Check}{26}{subsection.3.6}\protected@file@percent }
\newlabel{ssec:saliency}{{3.6}{26}{Saliency as a Sanity Check}{subsection.3.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Occlusion-based saliency for four representative misclassified test sequences from the dominant within-class superfamily confusion pairs (DNA/hAT$\rightarrow $DNA, LTR/Gypsy$\rightarrow $LTR/Pao, DNA$\rightarrow $DNA/hAT, LINE/L1$\rightarrow $LINE/L1-Tx1) identified on the v4. For each example, two curves show the per-position drop in the true-class logit (blue) and in the predicted-class logit (orange) when a sliding window is masked, so positive values mark regions important for the corresponding class. A confident error like LINE/L1$\rightarrow $LINE/L1-Tx1 typically shows broadly negative true-class saliency across the body, while ambiguous within-class errors (LTR/Gypsy$\leftrightarrow $LTR/Pao) show overlapping true- and predicted-class envelopes consistent with shared internal motifs.}}{26}{figure.caption.37}\protected@file@percent }
\newlabel{fig:saliency_analysis}{{11}{26}{Occlusion-based saliency for four representative misclassified test sequences from the dominant within-class superfamily confusion pairs (DNA/hAT$\rightarrow $DNA, LTR/Gypsy$\rightarrow $LTR/Pao, DNA$\rightarrow $DNA/hAT, LINE/L1$\rightarrow $LINE/L1-Tx1) identified on the v4. For each example, two curves show the per-position drop in the true-class logit (blue) and in the predicted-class logit (orange) when a sliding window is masked, so positive values mark regions important for the corresponding class. A confident error like LINE/L1$\rightarrow $LINE/L1-Tx1 typically shows broadly negative true-class saliency across the body, while ambiguous within-class errors (LTR/Gypsy$\leftrightarrow $LTR/Pao) show overlapping true- and predicted-class envelopes consistent with shared internal motifs}{figure.caption.37}{}}
